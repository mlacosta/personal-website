---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://www.linkedin.com/in/mlacosta/" target="_blank" rel="noopener noreferrer">
				<span class="sr-only">Visit Mariano Acosta on LinkedIn</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M1.146 1.146C1.782.51 2.842.5 3.49 1.148c.646.646.636 1.705 0 2.342-.637.637-1.696.646-2.342 0A1.657 1.657 0 0 1 1.146 1.146zM.5 5h3v10h-3V5zm5 0h2.875v1.375h.041C8.816 5.609 9.824 5 11.063 5 13.78 5 14.5 6.709 14.5 9.244V15h-3V9.953c0-1.204-.021-2.752-1.677-2.752-1.679 0-1.936 1.31-1.936 2.663V15h-3V5z"
					></path></svg
				>
			</a>
			<a href="https://github.com/mlacosta" target="_blank" rel="noopener noreferrer">
				<span class="sr-only">Visit Mariano Acosta on GitHub</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg
				>
			</a>
			<a href="mailto:marianoacosta.003@gmail.com">
				<span class="sr-only">Send an email to Mariano Acosta</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v.217l-8 4.8-8-4.8V4zm0 1.383V12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V5.383l-7.485 4.491a1 1 0 0 1-1.03 0L0 5.383z"
					></path></svg
				>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1rem;
		background: var(--surface);
		border-bottom: 1px solid var(--line);
	}
	h2 {
		margin: 0;
		font-size: 0.95rem;
		font-family: var(--font-sans);
		font-weight: 500;
		letter-spacing: 0.01em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
		color: var(--text);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		min-height: 3.4rem;
	}
	nav a {
		padding: 0.65rem 0.35rem;
		color: var(--text-muted);
		border-bottom: 1px solid transparent;
		text-decoration: none;
		font-family: var(--font-sans);
		font-size: 0.9rem;
		transition:
			color 160ms ease,
			border-color 160ms ease;
	}
	nav a:hover {
		color: var(--text);
	}
	nav a.active {
		color: var(--text);
		border-bottom-color: var(--line);
	}
	.social-links,
	.social-links a {
		display: flex;
	}
	.social-links {
		gap: 0.25rem;
	}
	.social-links a {
		color: var(--text-muted);
	}
	.social-links a:hover {
		color: var(--text);
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
</style>
